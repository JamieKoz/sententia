{
  "name": "sententia",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run deploy:staging",
    "deploy:staging": "npm run build && wrangler deploy --keep-vars",
    "deploy:production": "CLOUDFLARE_ENV=production npm run build && wrangler deploy --env production --keep-vars",
    "deploy:production:dry-run": "CLOUDFLARE_ENV=production npm run build && wrangler deploy --env production --keep-vars --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -b && tsc --noEmit -p tsconfig.worker.json",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "@cloudflare/workers-types": "^4.20260412.1",
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.4.1",
    "vitest": "^2.1.9",
    "wrangler": "^4.81.1"
  }
}
