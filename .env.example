# Worker-only secrets for local dev: copy to `.dev.vars` (gitignored).
# Production: set the same names in the Cloudflare dashboard (not VITE_*).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODELS=gpt-4.1-mini,gpt-4.1
TMDB_READ_ACCESS_TOKEN=

# Turnstile (https://dash.cloudflare.com → Turnstile). For local dev you can use
# Cloudflare test keys (always pass): site 1x00000000000000000000AA, secret 1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Max OpenAI proxy calls per IP per UTC day (default 30 if unset)
AI_DAILY_LIMIT=30

# Frontend (Vite build) — Amazon Associates tags per region (Prime "Watch now")
# VITE_AMAZON_ASSOCIATE_TAG=yourtag-20
# VITE_AMAZON_TAG_US=yourtag-20
# VITE_AMAZON_TAG_AU=yourtag-20
# VITE_AMAZON_TAG_GB=yourtag-21

# After creating KV namespaces, paste IDs into wrangler.toml:
#   npx wrangler kv namespace create RATE_KV
#   npx wrangler kv namespace create RATE_KV --preview
